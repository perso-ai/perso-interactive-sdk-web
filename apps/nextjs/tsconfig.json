{
	"extends": "@perso-interactive-sdk-web/tsconfig/tsconfig.base.json",
	"compilerOptions": {
		"target": "ES2022",
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"jsx": "preserve",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"noEmit": true,
		"isolatedModules": true,
		"incremental": true,
		"plugins": [{ "name": "next" }],
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
	"exclude": ["node_modules"]
}
